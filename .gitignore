# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual Environments ---
# Common names for virtualenvs
venv/
env/
ENV/
.env/
.venv/

# --- Environment Variables (CRITICAL SECURITY) ---
.env
.env.local
.env.*.local
# Exceptions: You might want to commit an example file
!.env.example

# --- IDE Settings (VS Code / PyCharm) ---
.vscode/
.idea/
*.swp
*.swo

# --- Docker ---
# We generally DO NOT ignore Dockerfile or docker-compose.yml
# But we ignore local overrides if you use them
docker-compose.override.yml

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Alembic (Database Migrations) ---
# 1. Ignore cached python files in migrations
alembic/__pycache__/

# 2. DO NOT ignore the versions folder! 
# We explicitly "un-ignore" the .gitkeep file we just created
!alembic/versions/.gitkeep

# 3. Note: We WANT to track *.py files in alembic/versions/ 
# because they represent your database history.